# ============================================================
# Emerald Kingdom — Environment Variables Template
# ============================================================
# Salin file ini ke .env dan isi dengan nilai yang sesuai.
# JANGAN PERNAH commit file .env ke repository.
# ============================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host:5432/emerald_dev?sslmode=require"

# --- Redis (Upstash) ---
REDIS_URL="redis://default:password@host:6379"

# --- Cloudflare R2 (Object Storage) ---
R2_ACCOUNT_ID="your_account_id"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_BUCKET_NAME="emerald-kingdom"
R2_PUBLIC_URL="https://your-r2-domain.com"

# --- Enkripsi Data KYC (AES-256-GCM) ---
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your_64_char_hex_string_here"

# --- JWT Authentication ---
JWT_SECRET="your_jwt_secret_here"
JWT_EXPIRATION="7d"
JWT_REFRESH_SECRET="your_refresh_secret_here"
JWT_REFRESH_EXPIRATION="30d"

# --- Email (Resend) ---
RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="noreply@emeraldkingdom.com"

# --- Payment (Midtrans Sandbox) ---
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxx"
MIDTRANS_IS_PRODUCTION="false"

# --- Live Streaming (Agora.io) ---
AGORA_APP_ID="your_agora_app_id"
AGORA_APP_CERTIFICATE="your_agora_certificate"

# --- Push Notification (Firebase FCM) ---
FIREBASE_PROJECT_ID="your_project_id"
FIREBASE_PRIVATE_KEY="your_private_key"
FIREBASE_CLIENT_EMAIL="your_client_email"

# --- Application ---
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"
API_URL="http://localhost:3001"

# --- Rate Limiting ---
THROTTLE_TTL="60"
THROTTLE_LIMIT="100"
