# ══════════════════════════════════════════════
# Emerald Kingdom — Environment Variables
# Salin file ini ke .env.local dan isi nilainya.
# JANGAN commit .env.local ke version control!
# ══════════════════════════════════════════════

# ─── App ─────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ────────────────────────────────
DATABASE_URL="postgresql://neondb_owner:npg_xPFQpd0itq7A@ep-still-wind-aosn7i2w.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ─── JWT ─────────────────────────────────────
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GANTI_DENGAN_SECRET_ACAK_MIN_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m

JWT_REFRESH_SECRET=GANTI_DENGAN_SECRET_ACAK_LAIN_MIN_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ─── Resend (Email) ───────────────────────────
# Disiapkan untuk Step 2 & 4
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@emeraldkingdom.com
