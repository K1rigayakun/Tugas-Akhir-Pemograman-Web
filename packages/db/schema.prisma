generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String              @id @default(cuid())
  email               String              @unique
  username            String              @unique
  passwordHash        String
  emailVerified       Boolean             @default(false)
  rank                Rank                @default(CIVIS)
  totalExp            Int                 @default(0)
  winStreak           Int                 @default(0)
  longestStreak       Int                 @default(0)
  totalWins           Int                 @default(0)
  totalBids           Int                 @default(0)
  kycStatus           KYCStatus           @default(NONE)
  privacyMode         PrivacyMode         @default(PUBLIC)
  twoFactorEnabled    Boolean             @default(false)
  twoFactorSecret     String?
  notificationPrefs   Json                @default("{}")
  activeTitle         String?
  activeCoatFrame     String?
  activeNameEffect    String?
  activeWalletSkin    String?
  isSuspended         Boolean             @default(false)
  isBannedFromAuction Boolean             @default(false)
  suspendUntil        DateTime?
  adminRole           AdminRole?
  deletedAt           DateTime?
  createdAt           DateTime            @default(now())
  lastActiveAt        DateTime            @default(now())
  otpExpiresAt        DateTime?
  otpHash             String?
  activeWebCodeId     String?
  activeBannerId      String?
  hiddenVaultItems    Json                @default("{\"auctions\": [], \"cosmetics\": []}")
  avatarUrl           String?
  watchlists          AuctionWatchlist[]
  wonAuctions         Auction[]           @relation("AuctionWinner")
  auditLogs           AuditLog[]          @relation("AdminActions")
  bids                Bid[]
  deliveries          Delivery[]
  expEvents           ExpEvent[]
  notifications       Notification[]
  phantomBids         PhantomBid[]
  rankHistory         RankHistory[]
  sessions            Session[]
  shopTransactions    ShopTransaction[]
  reviewedTopUps      TopUpRequest[]      @relation("AdminTopUps")
  topUpRequests       TopUpRequest[]      @relation("UserTopUps")
  achievements        UserAchievement[]
  address             UserAddress?
  cosmetics           UserCosmetic[]
  reviewedKYCs        UserKYC[]           @relation("KYCReviewer")
  kyc                 UserKYC?
  questProgress       UserQuestProgress[]
  vaultSubmissions    VaultSubmission[]
  walletAccount       WalletAccount?

  @@map("users")
}

model UserKYC {
  id             String    @id @default(cuid())
  userId         String    @unique
  fullName       String?
  nationalId     String?
  dateOfBirth    String?
  phoneNumber    String?
  streetAddress  String?
  city           String?
  province       String?
  country        String    @default("Indonesia")
  postalCode     String?
  idDocumentKey  String?
  selfieKey      String?
  reviewedBy     String?
  reviewNotes    String?
  submittedAt    DateTime  @default(now())
  reviewedAt     DateTime?
  kycStatus      KYCStatus @default(PENDING)
  nationalIdHash String?   @unique
  reviewer       User?     @relation("KYCReviewer", fields: [reviewedBy], references: [id])
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_kyc")
}

model Auction {
  id                    String             @id @default(cuid())
  title                 String
  description           String
  category              String
  rarity                ItemRarity         @default(COMMON)
  auctionType           AuctionType        @default(STANDARD)
  status                AuctionStatus      @default(DRAFT)
  startingPrice         Int
  currentPrice          Int                @default(0)
  minimumIncrement      Int                @default(1)
  minimumPrice          Int?
  decrementAmount       Int?
  startTime             DateTime
  endTime               DateTime
  minimumRank           Rank?
  isSealed              Boolean            @default(false)
  imageUrls             String[]
  videoUrl              String?
  modelUrl              String?
  winnerId              String?
  finalPrice            Int?
  inMuseum              Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  requiredAchievementId String?
  watchlists            AuctionWatchlist[]
  winner                User?              @relation("AuctionWinner", fields: [winnerId], references: [id])
  bids                  Bid[]
  delivery              Delivery?
  museumItem            MuseumItem?
  phantomBids           PhantomBid[]

  @@index([status])
  @@index([auctionType])
  @@index([startTime])
  @@index([endTime])
  @@map("auctions")
}

model UserAddress {
  id          String   @id @default(cuid())
  userId      String   @unique
  recipient   String
  phoneNumber String
  address     String
  city        String
  province    String
  postalCode  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_addresses")
}

model Delivery {
  id           String    @id @default(cuid())
  auctionId    String    @unique
  userId       String
  status       String    @default("PENDING")
  trackingResi String?
  courier      String?
  shippedAt    DateTime?
  deliveredAt  DateTime?
  recipient    String
  phoneNumber  String
  address      String
  city         String
  province     String
  postalCode   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  auction      Auction   @relation(fields: [auctionId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@map("deliveries")
}

model Bid {
  id         String    @id @default(cuid())
  auctionId  String
  userId     String
  amount     Int
  status     BidStatus @default(ACTIVE)
  isPhantom  Boolean   @default(false)
  phantomMax String?
  placedAt   DateTime  @default(now())
  auction    Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id])

  @@index([auctionId])
  @@index([userId])
  @@index([auctionId, amount])
  @@map("bids")
}

model WalletAccount {
  id           String              @id @default(cuid())
  userId       String              @unique
  balance      Int                 @default(0)
  pendingHold  Int                 @default(0)
  totalTopUp   Int                 @default(0)
  totalSpent   Int                 @default(0)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]

  @@map("wallet_accounts")
}

model WalletTransaction {
  id             String        @id @default(cuid())
  walletId       String
  type           WalletTxType
  amount         Int
  description    String
  referenceId    String?
  idempotencyKey String        @unique
  createdAt      DateTime      @default(now())
  wallet         WalletAccount @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([walletId, createdAt])
  @@index([type])
  @@map("wallet_transactions")
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  deviceInfo       String?
  ipAddress        String?
  createdAt        DateTime  @default(now())
  lastActiveAt     DateTime  @default(now())
  isActive         Boolean   @default(true)
  expiresAt        DateTime?
  refreshTokenHash String?
  userAgent        String?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Achievement {
  id               String            @id @default(cuid())
  name             String            @unique
  description      String
  tier             AchievementTier   @default(COMMON)
  trigger          String
  condition        Json
  expReward        Int               @default(0)
  titleReward      String?
  cosmeticReward   String?
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Cosmetic {
  id                  String         @id @default(cuid())
  name                String         @unique
  type                CosmeticType
  rarity              CosmeticRarity @default(COMMON)
  imageUrl            String
  previewUrl          String?
  obtainMethod        ObtainMethod   @default(SHOP)
  webCode             String?
  customEffectUrl     String?
  description         String?
  linkedAchievementId String?
  linkedEventName     String?
  requiredRank        Rank?
  shopPrice           Int?
  splineUrl           String?
  userCosmetics       UserCosmetic[]

  @@map("cosmetics")
}

model UserCosmetic {
  id           String   @id @default(cuid())
  userId       String
  cosmeticId   String
  obtainedAt   DateTime @default(now())
  obtainedFrom String
  cosmetic     Cosmetic @relation(fields: [cosmeticId], references: [id])
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cosmeticId])
  @@map("user_cosmetics")
}

model RankHistory {
  id        String   @id @default(cuid())
  userId    String
  fromRank  Rank
  toRank    Rank
  changedAt DateTime @default(now())
  reason    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("rank_history")
}

model ExpEvent {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  reason     String
  multiplier Float    @default(1.0)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("exp_events")
}

model Event {
  id                  String   @id @default(cuid())
  name                String
  theme               String
  backgroundMode      String?
  accentColors        Json     @default("[]")
  expMultiplier       Float    @default(1.0)
  startTime           DateTime
  endTime             DateTime
  isActive            Boolean  @default(false)
  createdAt           DateTime @default(now())
  defaultBannerId     String?
  defaultCoatFrameId  String?
  defaultNameEffectId String?
  themeConfig         Json?    @default("{}")

  @@map("events")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      NotifType
  payload   Json      @default("{}")
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetId   String?
  targetType String?
  details    Json     @default("{}")
  ipAddress  String?
  timestamp  DateTime @default(now())
  admin      User     @relation("AdminActions", fields: [adminId], references: [id])

  @@index([adminId])
  @@index([timestamp])
  @@index([action])
  @@map("audit_logs")
}

model ShopItem {
  id             String            @id @default(cuid())
  name           String
  type           String
  cosmeticId     String?
  price          Int
  stock          Int?
  isLimited      Boolean           @default(false)
  flashSalePrice Int?
  flashSaleEnd   DateTime?
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  transactions   ShopTransaction[]

  @@map("shop_items")
}

model ShopTransaction {
  id             String   @id @default(cuid())
  userId         String
  shopItemId     String
  pricePaid      Int
  idempotencyKey String   @unique
  purchasedAt    DateTime @default(now())
  shopItem       ShopItem @relation(fields: [shopItemId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("shop_transactions")
}

model DailyQuest {
  id          String              @id @default(cuid())
  title       String
  description String
  condition   Json                @default("{}")
  expReward   Int                 @default(0)
  isActive    Boolean             @default(true)
  progress    UserQuestProgress[]

  @@map("daily_quests")
}

model UserQuestProgress {
  id          String     @id @default(cuid())
  userId      String
  questId     String
  date        DateTime   @db.Date
  progress    Int        @default(0)
  isCompleted Boolean    @default(false)
  claimedAt   DateTime?
  quest       DailyQuest @relation(fields: [questId], references: [id])
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, date])
  @@index([userId, date])
  @@map("user_quest_progress")
}

model MuseumItem {
  id         String   @id @default(cuid())
  auctionId  String   @unique
  featuredAt DateTime @default(now())
  editorial  String?
  auction    Auction  @relation(fields: [auctionId], references: [id])

  @@map("museum_items")
}

model AuctionWatchlist {
  id        String   @id @default(cuid())
  userId    String
  auctionId String
  addedAt   DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@map("auction_watchlists")
}

model PhantomBid {
  id        String   @id @default(cuid())
  userId    String
  auctionId String
  maxAmount String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@map("phantom_bids")
}

model PlatformContent {
  id        String      @id @default(cuid())
  type      ContentType
  title     String
  content   String
  imageUrl  String?
  isActive  Boolean     @default(true)
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("platform_content")
}

model SecurityRule {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  isBlocked Boolean  @default(true)
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("security_rules")
}

model TopUpRequest {
  id             String      @id @default(cuid())
  userId         String
  amount         Int
  fiatAmount     Int
  method         String
  provider       String?
  bank           String?
  walletType     String?
  status         TopUpStatus @default(PENDING)
  proofImageUrl  String?
  paymentDetails Json?
  expiresAt      DateTime?
  paidAt         DateTime?
  adminNotes     String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  admin          User?       @relation("AdminTopUps", fields: [reviewedBy], references: [id])
  user           User        @relation("UserTopUps", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([method])
  @@index([expiresAt])
  @@map("topup_requests")
}

model VaultSubmission {
  id            String   @id @default(cuid())
  userId        String
  title         String
  description   String
  rarity        String   @default("COMMON")
  startingPrice Int
  imageUrls     String[]
  status        String   @default("PENDING")
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("vault_submissions")
}

enum TopUpStatus {
  PENDING
  PAID
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum Rank {
  CIVIS
  MERCHANT
  KNIGHT
  BARON
  VISCOUNT
  EARL
  MARQUIS
  DUKE
  SOVEREIGN
  EMPEROR
}

enum ItemRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  TRANSCENDENT
}

enum CosmeticRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum CosmeticType {
  FRAME
  BANNER
  NAME_EFFECT
  WALLET_SKIN
  CHAT_EFFECT
  WEB_CODE
}

enum ObtainMethod {
  SHOP
  ACHIEVEMENT
  RANK
  EVENT
  AUCTION
}

enum AuctionType {
  STANDARD
  SCHEDULED
  LIVE
  RANK_EXCL
  SEALED_CHEST
  DESCENDING
}

enum AuctionStatus {
  DRAFT
  UPCOMING
  ACTIVE
  ENDING
  ENDED
  CANCELLED
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  REFUNDED
}

enum KYCStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum WalletTxType {
  TOP_UP
  BID_HOLD
  BID_RELEASE
  BID_DEDUCT
  CASHBACK
  SHOP_PURCHASE
  REFUND
  BONUS
}

enum NotifType {
  OUTBID
  AUCTION_ENDING_SOON
  YOU_WON
  LIVE_AUCTION_START
  RANK_UP
  NEW_ACHIEVEMENT
  EVENT_STARTING
  CASHBACK_RECEIVED
  KYC_STATUS
  SECURITY_ALERT
  EMPEROR_ASCENSION
}

enum PrivacyMode {
  PUBLIC
  ANONYMOUS
  SHADOW
}

enum AchievementTier {
  COMMON
  RARE
  EPIC
}

enum AdminRole {
  SUPER_ADMIN
  AUCTION_MANAGER
  KYC_OFFICER
  CONTENT_MANAGER
  SUPPORT_OFFICER
}

enum ContentType {
  BANNER
  NEWS
  FAQ
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}
